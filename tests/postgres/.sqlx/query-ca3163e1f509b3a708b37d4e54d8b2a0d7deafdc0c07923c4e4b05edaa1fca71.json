{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT items.id, items.name, items.price, items.stock\n        FROM items\n        JOIN categories ON categories.id = items.category_id\n        WHERE items.category_id = $1\n        AND   items.price      >= $2\n        ORDER BY items.created_at DESC LIMIT $3 OFFSET $4\n        ",
