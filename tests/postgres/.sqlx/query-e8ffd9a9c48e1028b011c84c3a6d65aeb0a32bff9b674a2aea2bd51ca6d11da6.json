{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            p.id,\n            p.name,\n            p.price,\n            p.stock,\n            p.category\n        FROM products p\n        WHERE 1 = 1\n         AND p.category = $1 \n         AND p.price >= $2 \n         AND p.price <= $3 \n         AND p.stock > 0 \n         ORDER BY p.id ASC \n         LIMIT $4 OFFSET $5 \n        ",
