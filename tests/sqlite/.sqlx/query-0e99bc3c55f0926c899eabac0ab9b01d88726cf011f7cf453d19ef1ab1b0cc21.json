  "query": "\n        SELECT\n            p.id,\n            p.name,\n            p.price,\n            p.stock,\n            p.category\n        FROM products p\n        WHERE 1 = 1\n         AND p.category = ? \n         AND p.price >= ? \n         AND p.price <= ? \n         AND p.stock > 0 \n         ORDER BY p.price ASC \n         LIMIT ? OFFSET ? \n        ",
